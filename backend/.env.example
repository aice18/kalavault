# Database Configuration - Required
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/kalavault?schema=public

# Redis Configuration - Required
# Format: redis://[:password]@host:port/db
REDIS_URL=redis://localhost:6379

# JWT Configuration - Required (minimum 32 characters each)
JWT_SECRET=replace_this_secret_min_32_chars_long_required_!!!!
JWT_REFRESH_SECRET=replace_this_refresh_secret_min_32_chars_long_required_!!!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cloudflare R2 Configuration - Required for image uploads
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_BUCKET=kalavault-artworks
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key

# Server Configuration
NODE_ENV=development
PORT=4000

# CORS Configuration - Whitelist frontend domains
FRONTEND_URL=http://localhost:3000

# Razorpay Integration (Optional)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Zoho Sign Integration (Optional)
ZOHO_SIGN_CLIENT_ID=your_zoho_client_id
ZOHO_SIGN_CLIENT_SECRET=your_zoho_client_secret

# Logging Configuration
LOG_LEVEL=debug

